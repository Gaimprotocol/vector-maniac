# Vector Maniac - Environment Configuration
# Copy this file to .env and fill in your values
# The app works in demo mode without these keys

# ===========================================
# RevenueCat (In-App Purchases)
# ===========================================
# Get your API keys from: https://app.revenuecat.com/
# Leave empty or remove for demo mode
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=

# ===========================================
# Google AdMob (Advertising)
# ===========================================
# Get your ad unit IDs from: https://admob.google.com/
# Note: App IDs must also be configured in native config files
# Leave empty or remove for demo mode
VITE_ADMOB_IOS_REWARDED_ID=
VITE_ADMOB_ANDROID_REWARDED_ID=

# ===========================================
# Feature Flags
# ===========================================
# Set to 'false' to disable ads completely
VITE_ENABLE_ADS=true
# Set to 'true' to use test ads during development
VITE_USE_TEST_ADS=true
