# Vector Maniac - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# RevenueCat (In-App Purchases)
# ===========================================
# Get your API keys from: https://app.revenuecat.com/
VITE_REVENUECAT_IOS_KEY=appl_your_ios_key_here
VITE_REVENUECAT_ANDROID_KEY=goog_your_android_key_here

# ===========================================
# Google AdMob (Advertising)
# ===========================================
# Get your ad unit IDs from: https://admob.google.com/
# Note: App IDs must also be configured in native config files
VITE_ADMOB_IOS_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
VITE_ADMOB_ANDROID_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ===========================================
# Feature Flags
# ===========================================
VITE_ENABLE_ADS=true
VITE_USE_TEST_ADS=false
